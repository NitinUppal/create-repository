# OpenAI API Key for enhanced contract analysis (optional)
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration
# SQLite (default)
DATABASE_URL=sqlite:///contracts.db

# PostgreSQL example
# DATABASE_URL=postgresql://username:password@localhost:5432/contracts

# MySQL example  
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/contracts

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Default directories for contract scanning
CONTRACT_INPUT_DIR=./contracts
CONTRACT_OUTPUT_DIR=./output